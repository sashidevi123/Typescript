Message.tsx

type MessageProps = {
  isLoggedIn: boolean;
};

function Message({ isLoggedIn }: MessageProps) {
  if (isLoggedIn) {
    return <h2>Welcome User!</h2>;
  } else {
    return <h2>Please sign in</h2>;
  }
}

export default Message;



