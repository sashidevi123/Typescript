App.tsx

import Message from "./Message";

function App() {
  const isLoggedIn = false;

  return (
    <div>
      <h1>Hey user did you signed in?</h1>
      <Message isLoggedIn={isLoggedIn} />
    </div>
  );
}

export default App;



